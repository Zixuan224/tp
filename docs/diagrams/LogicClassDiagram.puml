@startuml
!include style.puml
skinparam arrowThickness 1.1
skinparam arrowColor LOGIC_COLOR_T4
skinparam classBackgroundColor LOGIC_COLOR

package Logic as LogicPackage {

package "Parser Classes" as ParserClasses {
}

Class CommandResult
Class "{abstract}\nCommand" as Command
Class "<<interface>>\nUndoableCommand" as UndoableCommand

' --- Specific Commands (Representative Sample) ---
Class AddGameCommand
Class ThemeCommand

Class "<<interface>>\nLogic" as Logic
Class LogicManager
}

package Model {
Class HiddenModel #FFFFFF
}

package Storage {
}

Class HiddenOutside #FFFFFF
HiddenOutside ..> Logic

LogicManager .right.|> Logic
LogicManager -right->"1" ParserClasses

' Parsers creating specific commands
ParserClasses ..> AddGameCommand : <<create>>
ParserClasses ..> ThemeCommand : <<create>>

' --- Inheritance & Implementation ---

' All commands extend the base abstract Command class
AddGameCommand -up-|> Command
ThemeCommand -up-|> Command

' Only data-mutating commands implement the UndoableCommand interface
AddGameCommand .left.|> UndoableCommand

' --- Notes for Abstraction ---
note bottom of AddGameCommand
  Other game, alias, and mutating commands
  (e.g., DeleteGameCommand, AddAliasCommand, EditCommand)
  follow this pattern and implement UndoableCommand.
end note

note bottom of ThemeCommand
  Standard non-mutating commands
  (e.g., ListCommand, HelpCommand, UndoCommand)
  follow this pattern and extend Command directly.
end note

LogicManager .left.> Command : <<call>>

LogicManager --> Model
LogicManager --> Storage
Storage --[hidden] Model
Command .right.> Model

Logic ..> CommandResult
LogicManager .down.> CommandResult
Command .up.> CommandResult : <<create>>
@enduml